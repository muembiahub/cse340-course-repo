<%- include('partials/header') %>
x
<main class="container">
  <h1><%= title %></h1>
  <section class="projects">
    <ul class="project-list">
        <li class="project-item">
          <article>
            <header>
              <h2><%= project.project_title %></h2>
            </header>
         
            <p><strong>Description:</strong> <%= project.description %></p>
            <p><strong>Location:</strong> <%= project.location %></p>
            <p><strong>Date:</strong> 
              <%= new Date(project.project_date).toLocaleDateString('en-US', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                  }) %>
            </p>
               <p><strong>Categories: </strong>
  <% project.category_names.forEach((cat, i) => { %>
    <a href="/categorydetails/<%= project.category_ids[i] %>"><%= cat %></a>
  <% }) %>
</p>
            <p>
              <strong>Organization:</strong><a href="/organizationdetails/<%= project.organization_id %>"> <%= project.organization_name %></a>
            </p>
           


          </article>
        </li>
    </ul>
  </section>

  <section class="get-involved">
    <h2>Get Involved</h2>
    <p>Join us in making a difference. Click below to explore opportunities and participate in our initiatives.</p>
    <button class="pulse"><%= button %></button>
  </section>
</main>

<%- include('partials/footer') %>
