<%- include('partials/header') %>

<main>  
  <section class="organizations">
    <h2>Our Partner Organizations</h2>
    <p>Here are a few of our partner organizations:</p>
    <ul class="organization-list">
      <% organizations.forEach(organization => { %>
        <li class="organization-item">
          <img 
            src="/images/<%= organization.logo_filename %>" 
            alt="<%= organization.name %> logo" 
            class="organization-logo"
          >
          <div class="organization-info">
            <h3><a href="/organizationdetails/<%= organization.organization_id %>"><%= organization.name %></a></h3>
            <p>
              Contact: 
              <a href="mailto:<%= organization.contact_email %>">
                <%= organization.contact_email %>
              </a>
            </p>
          </div>
        </li>
      <% }); %>
    </ul>
  </section>

  <section class="get-involved">
    <h2>Get Involved</h2>
    <button class="pulse" aria-label="Get involved"><%= button %></button>
  </section>
</main>

<%- include('partials/footer') %>
